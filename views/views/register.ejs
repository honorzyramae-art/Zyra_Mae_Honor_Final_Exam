<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title><%= title %> - SIMS</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 40px; background-color: #f4f7f6; }
        nav { margin-bottom: 20px; padding: 10px; background: #333; }
        nav a { color: white; margin-right: 15px; text-decoration: none; }
        .form-container { background: white; padding: 25px; border-radius: 8px; max-width: 500px; box-shadow: 0 0 10px rgba(0,0,0,0.1); }
        .form-group { margin-bottom: 15px; }
        label { display: block; margin-bottom: 5px; font-weight: bold; }
        input, select { width: 100%; padding: 8px; box-sizing: border-box; border: 1px solid #ccc; border-radius: 4px; }
        button { background: #28a745; color: white; padding: 10px 15px; border: none; border-radius: 4px; cursor: pointer; font-size: 16px; }
    </style>
</head>
<body>

    <nav>
        <a href="/">Homepage / Student List</a>
        <a href="/register">Register New Student</a>
    </nav>

    <div class="form-container">
        <h2>Student Registration</h2>
        <form action="/register" method="POST">
            <div class="form-group">
                <label>Student ID</label>
                <input type="text" name="student_id" placeholder="e.g., 2026-0001" required>
            </div>
            <div class="form-group">
                <label>Full Name</label>
                <input type="text" name="full_name" placeholder="e.g., Cardo Dalisay" required>
            </div>
            <div class="form-group">
                <label>Course</label>
                <input type="text" name="course" placeholder="e.g., BS Computer Science" required>
            </div>
            <div class="form-group">
                <label>Year Level</label>
                <select name="year_level" required>
                    <option value="">--Select Year Level--</option>
                    <option value="1st Year">1st Year</option>
                    <option value="2nd Year">2nd Year</option>
                    <option value="3rd Year">3rd Year</option>
                    <option value="4th Year">4th Year</option>
                </select>
            </div>
            <div class="form-group">
                <label>Email Address</label>
                <input type="email" name="email_address" placeholder="e.g., cardo@example.com" required>
            </div>
            <button type="submit">Submit Registration</button>
        </form>
    </div>

</body>
</html>
